# Get your Anthropic API key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Get your NewsAPI key from https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Optional: EventBrite API key from https://www.eventbrite.com/platform/api
EVENTBRITE_API_KEY=

# Supabase JWT verification (from Supabase Dashboard > Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=

# Google Places API key from https://console.cloud.google.com/apis/credentials
# Free tier: 5,000 text searches/month — used for real-time restaurant data
GOOGLE_PLACES_API_KEY=

PORT=8080
